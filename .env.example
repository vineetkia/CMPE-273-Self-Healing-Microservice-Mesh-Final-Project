# LLM-driven reasoning for the healing agent.
# Uses an OpenAI-compatible chat completions endpoint (Azure AI Foundry works).
# When unset, the agent falls back to deterministic rule-based reasoning.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=

# Optional: Pydantic Logfire write token. When set, the healer ships traces
# of llm_diagnose, send_control, and incident_iteration to Logfire's hosted
# UI. Demo runs identically when unset.
LOGFIRE_TOKEN=
